{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "BASE_PATH=/ pnpm --filter @workspace/royvento run build && pnpm --filter @workspace/api-server run build",
    "watchPatterns": [
      "artifacts/api-server/**",
      "artifacts/royvento/**",
      "lib/**",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "tsconfig.base.json"
    ]
  }
}
