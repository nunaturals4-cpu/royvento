{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "dev:local": "pnpm run build && node --enable-source-maps --env-file=.env.local ./dist/index.mjs",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "seed": "tsx src/scripts/seed.ts",
    "seed:reviews": "tsx src/scripts/seedPubReviews.ts",
    "seed:demo-pubs": "tsx src/scripts/seedDemoPubsProd.ts",
    "seed:showcase": "tsx --env-file=.env.local src/scripts/seedShowcase.ts",
    "migrate:media": "tsx src/scripts/migrateMediaToS3.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.0",
    "@google-cloud/storage": "^7.19.0",
    "@types/nodemailer": "^8.0.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "express-rate-limit": "^8.4.1",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.10",
    "pino": "^9",
    "pino-http": "^10",
    "sharp": "^0.34.5",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "catalog:",
    "@types/node-cron": "^3.0.11",
    "@types/web-push": "^3.6.4",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
}
