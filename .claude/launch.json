{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "royvento",
      "cwd": "artifacts/royvento",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "api-server",
      "cwd": "artifacts/api-server",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "dev:local"],
      "port": 5000
    },
    {
      "name": "mockup-sandbox",
      "cwd": "artifacts/mockup-sandbox",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "dev"],
      "port": 3001,
      "env": {
        "PORT": "3001",
        "BASE_PATH": "/"
      }
    },
    {
      "name": "mobile",
      "cwd": "artifacts/mobile",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "dev"],
      "port": 8081,
      "env": {
        "PORT": "8081"
      }
    }
  ]
}
